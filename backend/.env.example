# Copy this file to .env and fill in real SMTP credentials.
# Do not commit .env.

FRONTEND_URL=http://localhost:3000

# Mailtrap example. You can replace these with Gmail SMTP, SendGrid SMTP, or another provider.
MAIL_SERVER=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@nepfluence.com
MAIL_USE_TLS=true

# Social discovery ingestion (Phase 0 accuracy harness + Phase 1 discovery_ingest_service).
# TIKHUB_API_KEY is required to run backend/scripts/accuracy/run_accuracy_test.py and to
# use discovery ingestion for Instagram/TikTok. Get a key at https://user.tikhub.io.
# Never used for verified/payout-grade data - see social_ingest/providers/registry.py.
TIKHUB_API_KEY=
TIKHUB_BASE_URL=https://api.tikhub.io
# Optional: only needed to run the accuracy harness's ScrapeCreators comparison arm.
SCRAPECREATORS_API_KEY=
# Requires a local/dev Redis instance (e.g. `docker run -p 6379:6379 redis:7`).
REDIS_URL=redis://localhost:6379/0
DISCOVERY_DAILY_REQUEST_BUDGET=500

# Social connect (verified OAuth "connect your account" plane - src/social_connect/).
# Fernet key used to encrypt stored OAuth access/refresh tokens at rest. Generate a real one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# and put it in .env only (never commit). Empty here on purpose.
TOKEN_ENCRYPTION_KEY=
# YouTube connect reuses the same GOOGLE_CLIENT_ID/SECRET as login but with a dedicated callback.
# This exact URI must be listed in the Google OAuth client's Authorized redirect URIs.
# Host is "localhost" (not "127.0.0.1") - must match the frontend's default API host
# (NEXT_PUBLIC_API_URL) since the connect flow binds `state` to a host-scoped session cookie.
GOOGLE_YOUTUBE_REDIRECT_URI=http://localhost:8000/social-connect/youtube/callback
# Instagram (Meta) and TikTok connect clients - dormant until the user registers developer apps
# (and, for Instagram, passes Meta App Review). Leave empty to keep those platforms disabled.
META_CLIENT_ID=
META_CLIENT_SECRET=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
